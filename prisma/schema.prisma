generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  SUB_ADMIN
  STUDENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum BatchStatus {
  ACTIVE
  UPCOMING
  COMPLETED
}

enum BatchKind {
  FREE_SYSTEM
  STANDARD
}

enum TestStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum TestSource {
  MANUAL
  AI_GENERATED
}

enum SessionStatus {
  IN_PROGRESS
  SUBMITTED
  TIMED_OUT
  FORCE_SUBMITTED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum DocumentImportJobStatus {
  QUEUED
  PROCESSING
  SUCCEEDED
  FAILED
}

model User {
  id              String     @id @default(uuid()) @db.Uuid
  email           String     @unique
  name            String
  phone           String?
  phoneNormalized String?
  role            Role       @default(STUDENT)
  status          UserStatus @default(ACTIVE)
  otp             String?
  otpExpiry       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  batchEnrollments BatchStudent[]
  testsCreatedBy   Test[]           @relation("TestCreatedBy")
  testSessions     TestSession[]
  auditLogs        AuditLog[]
  testAssignments  TestAssignment[] @relation("StudentAssignments")
  documentImportJobs DocumentImportJob[]

  @@index([phoneNormalized])
}

model Batch {
  id        String      @id @default(uuid()) @db.Uuid
  name      String
  code      String      @unique
  kind      BatchKind   @default(STANDARD)
  status    BatchStatus @default(ACTIVE)
  createdAt DateTime    @default(now())

  students    BatchStudent[]
  assignments TestAssignment[]

  @@index([kind])
}

model BatchStudent {
  batchId   String @db.Uuid
  studentId String @db.Uuid

  batch   Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  student User  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([batchId, studentId])
  @@index([studentId]) // Student-centric lookups ("my batches")
}

model Test {
  id              String     @id @default(uuid()) @db.Uuid
  createdById     String     @db.Uuid
  title           String
  description     String?    @db.Text
  durationMinutes Int
  status          TestStatus @default(DRAFT)
  source          TestSource @default(MANUAL)
  reviewStatus    String?    @map("review_status")
  importDiagnostics Json?    @map("import_diagnostics")
  settings        Json       @default("{}")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  createdBy    User              @relation("TestCreatedBy", fields: [createdById], references: [id])
  questions    Question[]
  assignments  TestAssignment[]
  sessions     TestSession[]
  leadSessions LeadTestSession[]
  importJobs   DocumentImportJob[]

  @@index([createdById])
}

model Question {
  id          String     @id @default(uuid()) @db.Uuid
  testId      String     @db.Uuid
  order       Int
  stem        String     @db.Text
  sharedContext String?  @db.Text
  importEvidence Json?   @map("import_evidence")
  options     Json
  explanation String?    @db.Text
  difficulty  Difficulty @default(MEDIUM)
  topic       String?

  test Test @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId, order]) // Ordered question fetches
}

model TestAssignment {
  id         String   @id @default(uuid()) @db.Uuid
  testId     String   @db.Uuid
  batchId    String?  @db.Uuid
  studentId  String?  @db.Uuid
  assignedAt DateTime @default(now())

  test    Test   @relation(fields: [testId], references: [id], onDelete: Cascade)
  batch   Batch? @relation(fields: [batchId], references: [id], onDelete: Cascade)
  student User?  @relation("StudentAssignments", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([testId, batchId])
  @@index([studentId]) // Student assignment lookups
}

model TestSession {
  id             String        @id @default(uuid()) @db.Uuid
  testId         String        @db.Uuid
  studentId      String        @db.Uuid
  attemptNumber  Int           @default(1)
  status         SessionStatus @default(IN_PROGRESS)
  startedAt      DateTime      @default(now())
  serverDeadline DateTime
  submittedAt    DateTime?
  answers        Json?
  tabSwitchCount Int           @default(0)
  score          Int?
  totalMarks     Int
  percentage     Float?

  test       Test        @relation(fields: [testId], references: [id], onDelete: Cascade)
  student    User        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  aiFeedback AIFeedback?

  @@unique([testId, studentId, attemptNumber])
  @@index([testId, studentId])
  @@index([studentId, status]) // Student dashboard queries
}

model Lead {
  id              String    @id @default(uuid()) @db.Uuid
  name            String
  email           String?
  emailNormalized String?
  phone           String?
  phoneNormalized String?
  isReviewed      Boolean   @default(false)
  reviewedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  testSessions LeadTestSession[]

  @@index([emailNormalized])
  @@index([phoneNormalized])
  @@index([isReviewed, createdAt])
}

model LeadTestSession {
  id             String        @id @default(uuid()) @db.Uuid
  testId         String        @db.Uuid
  leadId         String        @db.Uuid
  status         SessionStatus @default(IN_PROGRESS)
  startedAt      DateTime      @default(now())
  serverDeadline DateTime
  submittedAt    DateTime?
  answers        Json?
  score          Int?
  totalMarks     Int
  percentage     Float?

  test Test @relation(fields: [testId], references: [id], onDelete: Cascade)
  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([testId, leadId])
  @@index([leadId, status])
}

model AIFeedback {
  id                   String   @id @default(uuid()) @db.Uuid
  testSessionId        String   @unique @db.Uuid
  strengths            Json
  weaknesses           Json
  actionPlan           Json
  questionExplanations Json
  overallTag           String?
  generatedAt          DateTime @default(now())

  testSession TestSession @relation(fields: [testSessionId], references: [id], onDelete: Cascade)
}

model DocumentImportJob {
  id             String                  @id @default(uuid()) @db.Uuid
  adminId        String                  @db.Uuid
  testId         String?                 @db.Uuid
  status         DocumentImportJobStatus @default(QUEUED)
  fileName       String
  mimeType       String
  fileSize       Int
  fileData       Bytes?
  requestedTitle String?                 @db.Text
  requestedCount Int?
  message        String?                 @db.Text
  errorCode      String?
  errorMessage   String?                 @db.Text
  result         Json?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  startedAt      DateTime?
  completedAt    DateTime?

  admin User  @relation(fields: [adminId], references: [id], onDelete: Cascade)
  test  Test? @relation(fields: [testId], references: [id], onDelete: SetNull)

  @@index([adminId, createdAt])
  @@index([adminId, status, createdAt])
  @@index([status, createdAt])
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  action    String
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
