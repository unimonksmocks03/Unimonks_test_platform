# Database
# Local: use localhost URLs. Vercel + Neon: DATABASE_URL must be the pooled URL, DIRECT_URL the direct URL.
DATABASE_URL="postgresql://user:pass@ep-example-pooler.us-east-1.aws.neon.tech/unimonk?sslmode=require&connect_timeout=15&pool_timeout=15"
DIRECT_URL="postgresql://user:pass@ep-example.us-east-1.aws.neon.tech/unimonk?sslmode=require&connect_timeout=15"

# Redis
# Local dev
REDIS_URL="redis://localhost:6379"
# Vercel + Upstash (preferred in production; if present these override REDIS_URL)
UPSTASH_REDIS_REST_URL="https://example.upstash.io"
UPSTASH_REDIS_REST_TOKEN=""

# Auth
JWT_SECRET="your_jwt_secret"
JWT_REFRESH_SECRET="your_refresh_secret"

# External APIs
OPENAI_API_KEY="sk-..."

# Gmail SMTP
GMAIL_USER="your-email@gmail.com"
GMAIL_APP_PASSWORD="your-16-char-app-password"
ENABLE_DEV_OTP_LOGS="false"

# Upstash QStash (serverless job queue)
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""
# Local dev with `npx @upstash/qstash-cli@latest dev`
QSTASH_URL=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
